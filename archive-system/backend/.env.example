PORT=5173
HOST=0.0.0.0
MAX_FILE_UPLOAD_MB=1000
MAX_FILES_PER_UPLOAD=20
PROJECT_SOURCE_URL=https://shenpi.drevan.cn/api/projects

ARK_ENABLED=1
ARK_API_KEY=ark-0efc080f-e823-4a17-8d7f-bacbb35c5096-71348
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_TEXT_MODEL=doubao-seed-2-1-pro-260628
ARK_VISION_MODEL=doubao-1-5-vision-pro-32k-250115
ARK_TIMEOUT_MS=120000
ARK_OCR_MAX_MB=8
ARK_EXTRACT_MAX_CHARS=12000
ARK_SUGGEST_MAX_INPUT=8000

EXTRACT_CONCURRENCY=2
EXTRACT_RETRIES=2
EXTRACT_RETRY_DELAY=5000

# ===== NAS 直连推送（可选） =====
# macOS 通过 Finder 连接 SMB/NFS 共享盘后，共享盘会自动挂载在 /Volumes/<共享名>
# 例如您挂载的共享盘名字叫「公司归档」，真实归档根目录是「公司归档/项目资料」，这里就填：
NAS_MOUNT_ROOT=/Volumes/公司归档/项目资料
# Windows/Linux 同理，填系统里能直接读写出文件的绝对路径即可

# 推送模式：copy（推荐，拷贝成功后原始文件保留在中转区）或 move（拷贝成功后从 10_ready_for_nas 删掉，省空间）
NAS_COPY_MODE=copy

# 如果 NAS 目标路径已经有同名文件，true=直接覆盖，false=报错并停止（推荐 false，避免误覆盖）
NAS_OVERWRITE_EXISTING=false
