# archive-standard.json 是归档规范配置（业务源代码的一部分），不忽略

# 上传 / 归档 / 审批队列的真实文件（包含用户数据，绝对不能提交）
archive-system/backend/storage/00_original_uploads/*
archive-system/backend/storage/10_ready_for_nas/*
archive-system/backend/storage/20_ai_working/*
archive-system/backend/storage/30_review_queue/*
archive-system/backend/storage/40_uploaded_records/*
archive-system/backend/storage/90_rejected/*
archive-system/backend/storage/logs/*
# 保留 .gitkeep 占位文件（如果后续创建的话）
!archive-system/backend/storage/**/.gitkeep

